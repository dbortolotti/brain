flowchart TB
  R01["R-01 Client asks Brain to recall"]
  R02["R-02 REST /memory/recall<br/>or HTTP MCP brain_recall"]
  R03["R-03 stdio MCP brain_recall"]
  R04{"R-04 Authenticated user?"}
  R05{"R-05 stdio token and<br/>user env valid?"}
  R06["R-06 Scope Settings<br/>to active user_id"]
  R07["R-07 Build RecallRequest<br/>query, mode, limit,<br/>include flags"]
  R08["R-08 recall() strips query"]
  R09{"R-09 Taste enabled and<br/>query looks like<br/>recommendation/ranking?"}
  R10["R-10 TasteService.query<br/>normalize intent and<br/>extract option entities"]
  R11["R-11 Retrieve taste candidates<br/>from CogneePalateStore"]
  R12["R-12 Use past decision feedback<br/>rank candidates<br/>build grounding"]
  R13["R-13 Log palate decision<br/>PalateDecisionDataPoint<br/>via Cognee"]
  R14["R-14 Return RecallResponse<br/>with taste answer,<br/>facts, evidence"]
  R15["R-15 Resolve recall mode<br/>explicit mode or infer"]
  R16{"R-16 Mode is profile?"}
  R17{"R-17 Requested owner profile?"}
  R18["R-18 Read profile context<br/>brain_context_records"]
  R19{"R-19 Context records found?"}
  R20["R-20 Return profile facts<br/>and evidence"]
  R21["R-21 Return no profile context"]
  R22{"R-22 Cognee recall enabled<br/>or injected searcher?"}
  R23["R-23 Cognee CHUNKS recall<br/>Brain dataset, top_k"]
  R24{"R-24 Cognee recall succeeded?"}
  R25["R-25 Convert raw chunks<br/>to normalized memories"]
  R26["R-26 Build facts and evidence<br/>from raw memories"]
  R27["R-27 Render Brain answer<br/>or no matches"]
  R28["R-28 Collect linked taste evidence<br/>from recalled result metadata"]
  R29["R-29 Return RecallResponse"]
  RERR["HTTP 401 or 403"]
  RSTDERR["stdio startup error"]
  REMPTY["R-30 Empty result list"]

  R01 --> R02
  R01 --> R03
  R02 --> R04
  R03 --> R05
