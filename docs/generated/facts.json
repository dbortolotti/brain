  "mcp_tools": {
    "internal": [
      {
        "description": "Resolve the active user's Brain profile and preference context for agents.",
        "name": "brain_session",
        "required": []
      },
      {
        "description": "Store a user-level memory, fact, thought, or short note in Brain. High-confidence palate memories may route to Brain Palate automatically. Do not use this for read-only palate describe/enrich requests; use brain_palate_describe_item instead.",
        "name": "brain_remember",
        "required": [
          "input"
        ]
      },
      {
        "description": "Store a stable user-profile fact that should always be returned by brain_session to tailor future answers.",
        "name": "brain_profile_context_remember",
        "required": [
          "statement"
        ]
      },
      {
        "description": "List standing user-profile context returned by brain_session.",
        "name": "brain_profile_context_list",
        "required": []
      },
      {
        "description": "Remove one standing user-profile context item by id.",
        "name": "brain_profile_context_forget",
        "required": [
          "context_id"
        ]
      },
      {
        "description": "Store a durable user preference, constraint, or response-style bias in Brain's control store.",
        "name": "brain_bias_context_remember",
        "required": [
          "statement"
        ]
      },
      {
        "description": "List durable user preferences, constraints, and response-style biases.",
        "name": "brain_bias_context_list",
        "required": []
      },
      {
        "description": "Remove one durable user bias/preference context item by id.",
        "name": "brain_bias_context_forget",
        "required": [
          "context_id"
        ]
      },
      {
        "description": "Project all standing profile-context items into the normal Brain memory/entity graph linked to the configured owner entity.",
        "name": "brain_profile_context_sync",
        "required": []
      },
      {
        "description": "Store source material in Brain through Cognee remember. Brain may detect palate mentions, but large source ingestion avoids mass palate enrichment/writes without confirmation.",
        "name": "brain_ingest_source",
        "required": [
          "source"
        ]
      },
      {
        "description": "Answer a user-level memory query with evidence. Recommendation-style palate queries may use Brain Palate ranking.",
        "name": "brain_recall",
        "required": [
          "query"
        ]
      },
      {
        "description": "Build an entity-centric Brain profile.",
        "name": "brain_profile_entity",
        "required": [
          "name"
        ]
      },
      {
        "description": "Forget a Cognee-backed Brain remember object via cognee.forget and write a status-event datapoint only as audit evidence. Hard delete requires confirm=true.",
        "name": "brain_forget",
        "required": [
          "object_id",
          "object_type"
        ]
      },
      {
        "description": "Review recent Brain control receipts, pending confirmations, and context records.",
        "name": "brain_review_recent",
        "required": []
      },
      {
        "description": "Soft-delete objects created by one recent ingestion run.",
        "name": "brain_undo_last",
        "required": []
      },
      {
        "description": "Run Cognee native improve on a configured Brain dataset.",
        "name": "cognee_improve",
        "required": []
      },
      {
        "description": "Read-only palate describe/enrich tool. Use this when the user asks to use palate to describe, look up, normalize, or enrich a restaurant, wine, film, series, music, cigar, or other taste item without saving it. For example: 'use palate to describe Junsei restaurant in London'. This must not store palate data.",
        "name": "brain_palate_describe_item",
        "required": [
          "entity_type",
          "item_text"
        ]
      },
      {
        "description": "Store an approved normalized palate item in the canonical palate store and project Brain evidence.",
        "name": "brain_palate_remember",
        "required": [
          "canonical_name",
          "description",
          "type"
        ]
      },
      {
        "description": "Rank already-saved canonical palate records for a recommendation or comparison query. Do not use this to describe, look up, enrich, or check a single named unsaved item such as Junsei; call brain_palate_describe_item for that.",
        "name": "brain_palate_query",
        "required": [
          "query"
        ]
      },
      {
        "description": "Rank only supplied options against already-saved canonical palate records. Do not use this to describe, look up, enrich, or check one named item; call brain_palate_describe_item for read-only item descriptions.",
        "name": "brain_palate_evaluate_options",
        "required": [
          "query"
        ]
      },
      {
        "description": "Record which palate item was chosen after a recommendation.",
        "name": "brain_palate_log_decision",
        "required": [
          "chosen_taste_item_id"
        ]
      },
      {
        "description": "Forget one canonical Brain Palate item by palate item ID, Brain palate entity ID, or canonical name. This soft-deletes the Cognee-backed palate item so it no longer appears in current Palate results.",
        "name": "brain_palate_forget",
        "required": []
      },
      {
        "description": "Confirm a pending palate proposal by proposal_id.",
        "name": "brain_palate_confirm",
        "required": [
          "proposal_id"
        ]
      },
      {
        "description": "Cancel a pending palate proposal by proposal_id.",
        "name": "brain_palate_cancel",
        "required": [
          "proposal_id"
        ]
      },
      {
        "description": "Apply a free-text correction to a pending palate proposal.",
        "name": "brain_palate_correct_proposal",
        "required": [
          "correction",
          "proposal_id"
        ]
      },
      {
        "description": "Refresh enrichment for one canonical palate item.",
        "name": "brain_palate_refresh_enrichment",
        "required": [
          "taste_item_id"
        ]
      }
    ]
  },
