<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.brain.prod.slack-agent</string>

  <key>UserName</key>
  <string>oric_prod</string>

  <key>GroupName</key>
  <string>staff</string>

  <key>SessionCreate</key>
  <true/>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/sh</string>
    <string>-c</string>
    <string>until [ -x /var/db/brain-prod/current-venv/bin/python ] &amp;&amp; [ -f /var/db/brain-prod/secrets/brain.env ] &amp;&amp; [ -d /Volumes/xpg_usb4/prod/brain/current ]; do sleep 5; done; unset PYTHONHOME PYTHONPATH; cd /var/db/brain-prod || exit 1; exec /var/db/brain-prod/current-venv/bin/python -m memory_stack.slack_agent_server</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/</string>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    <key>HOME</key>
    <string>/var/db/brain-prod</string>
    <key>BRAIN_CONFIG_DIR</key>
    <string>/var/db/brain-prod/cfg</string>
    <key>XDG_CACHE_HOME</key>
    <string>/var/db/brain-prod/cache</string>
    <key>UV_CACHE_DIR</key>
    <string>/var/db/brain-prod/uv-cache</string>
    <key>UV_PYTHON_INSTALL_DIR</key>
    <string>/var/db/brain-prod/python</string>
    <key>ENV_FILE</key>
    <string>/var/db/brain-prod/secrets/brain.env</string>
    <key>BRAIN_SLACK_AGENT_ENABLED</key>
    <string>true</string>
    <key>BRAIN_SLACK_AGENT_HOST</key>
    <string>127.0.0.1</string>
    <key>BRAIN_SLACK_AGENT_PORT</key>
    <string>18003</string>
  </dict>

  <key>StandardOutPath</key>
  <string>/Users/oric/Library/Logs/brain-slack-agent.out.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/oric/Library/Logs/brain-slack-agent.err.log</string>
</dict>
</plist>
